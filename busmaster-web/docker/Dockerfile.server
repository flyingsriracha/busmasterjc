FROM node:20-alpine AS build

WORKDIR /app

# Copy package files
COPY server/package*.json ./
RUN npm ci

# Copy source
COPY server/ ./

# Build TypeScript
RUN npm run build

# Production image
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY server/package*.json ./
RUN npm ci --only=production

# Copy built files
COPY --from=build /app/dist ./dist

# Create logs directory
RUN mkdir -p logs

EXPOSE 8080

CMD ["node", "dist/index.js"]

