# Server Configuration
NODE_ENV=development
PORT=8080
HOST=localhost

# CORS Settings
CORS_ORIGIN=http://localhost:3000

# WebSocket Settings
WS_PORT=8081

# Authentication (optional for now)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# Logging
LOG_LEVEL=debug

# Hardware Configuration
VIRTUAL_CAN_ENABLED=true
HARDWARE_SCAN_INTERVAL=5000

# Database (for configuration storage)
DB_PATH=./data/busmaster.db

# File Upload Limits
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

