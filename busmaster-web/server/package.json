{
  "name": "busmaster-web-server",
  "version": "0.1.0",
  "description": "BUSMASTER Web API Server - REST API and WebSocket server for CAN/LIN bus analysis",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build:native && tsc",
    "build:native": "node-gyp rebuild",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "can",
    "lin",
    "busmaster",
    "automotive",
    "bus-analysis"
  ],
  "author": "BUSMASTER Web Contributors",
  "license": "LGPL-3.0",
  "dependencies": {
    "express": "^5.0.1",
    "socket.io": "^4.8.1",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "dotenv": "^16.4.7",
    "winston": "^3.17.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "multer": "^2.0.0-rc.4",
    "node-addon-api": "^8.3.0",
    "node-gyp": "^10.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcrypt": "^5.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/multer": "^1.4.12",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
